# Backend settings
PORT=4000
APP_ENV=development
API_BASE_URL=https://api.applypilot.ai/v1

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/applypilot

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=replace_with_a_strong_secret
JWT_ACCESS_TOKEN_EXPIRES=15m
JWT_REFRESH_TOKEN_EXPIRES=30d

# OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://your-app-domain.com/api/auth/oauth/google

# AI Provider Defaults
AI_PROVIDER_ENDPOINT=https://localhost:11434
AI_PROVIDER_MODEL=llama-3.3-70b

# Sentry
SENTRY_DSN=
